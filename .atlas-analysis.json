  "keyFeatures": [
    "Apply and revert Windows optimization tweaks via PowerShell scripts",
    "Clean temporary files, prefetch, recycle bin, update cache, and thumbnails",
    "Manage DNS providers (Cloudflare, Google, OpenDNS, Quad9, AdGuard, custom)",
    "Install/uninstall 100+ apps via Winget and Chocolatey integration",
    "System utilities: disk cleaner, SFC, DISM, power plan, fast startup, and more",
    "GUI restore point manager for safe backup and revert",
    "Risk-level indicators (safe/caution/risky) for every tweak",
    "Auto-updates via electron-updater"
  ],
  "publicApiSurface": [
    "tweaks/*/meta.json — tweak metadata schema",
    "tweaks/*/apply.ps1 — tweak apply script",
    "tweaks/*/unapply.ps1 — tweak unapply script",
    "src/renderer/assets/apps.json — app installer registry",
    "tweaks/registry.json — registry tweak definitions",
    "tweaks/registry-scripts.json — registry script definitions"
  ]
